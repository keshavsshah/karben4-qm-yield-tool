# Example Streamlit secrets — copy to secrets.toml and fill in to enable SharePoint
# durable storage. secrets.toml is git-ignored (never commit real credentials).
# On Streamlit Community Cloud, paste these into: app → ⋮ → Settings → Secrets.
# Leave this file out / keys unset to keep using the local brewery_data.xlsx instead.
# See SHAREPOINT_SETUP.md for how Karben4 IT produces these values.

MS_TENANT_ID      = "your-tenant-id"
MS_CLIENT_ID      = "your-app-client-id"
MS_CLIENT_SECRET  = "your-client-secret-value"
MS_DRIVE_ID       = "the-sharepoint-library-drive-id"
MS_DATA_ITEM_PATH = "brewery_data.xlsx"   # or e.g. "Brewing/brewery_data.xlsx"
